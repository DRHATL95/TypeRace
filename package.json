{
    "name": "typeracer-desktop",
    "version": "1.0.0",
    "description": "A desktop TypeRacer game built with Electron and React",
    "main": "dist/main.js",
    "homepage": "/",
    "scripts": {
        "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:3000 && npm run dev:electron\"",
        "dev:renderer": "react-scripts start",
        "dev:electron": "electron .",
        "start": "react-scripts start",
        "build": "npm run build:renderer && npm run build:main",
        "build:renderer": "react-scripts build",
        "build:main": "tsc -p tsconfig.main.json",
        "build:web": "react-scripts build",
        "package": "npm run build && electron-builder",
        "package:mac": "npm run build && electron-builder --mac",
        "package:win": "npm run build && electron-builder --win",
        "package:linux": "npm run build && electron-builder --linux",
        "dev:server": "cd server && npm run dev",
        "dev:all": "concurrently \"npm run dev:renderer\" \"npm run dev:server\""
    },
    "author": "DRHATL95",
    "build": {
        "appId": "com.typerace.app",
        "productName": "TypeRace",
        "extends": null,
        "directories": {
            "output": "release"
        },
        "files": [
            "build/**/*",
            "dist/**/*"
        ],
        "extraMetadata": {
            "main": "dist/main.js"
        },
        "mac": {
            "category": "public.app-category.games",
            "target": "dmg"
        },
        "win": {
            "target": "nsis"
        },
        "linux": {
            "target": "AppImage"
        }
    },
    "dependencies": {
        "@clerk/clerk-react": "^5.61.4",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "concurrently": "^8.2.0",
        "electron": "^41.1.1",
        "electron-builder": "^26.8.1",
        "react-scripts": "5.0.1",
        "typescript": "^4.9.5",
        "wait-on": "^7.0.0"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    }
}
