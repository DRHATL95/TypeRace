{
  "name": "typerace-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc && npm run copy-migrations",
    "copy-migrations": "node -e \"const fs=require('fs'),p=require('path');const s=p.join('src','db','migrations'),d=p.join('dist','db','migrations');fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).filter(f=>f.endsWith('.sql')).forEach(f=>fs.copyFileSync(p.join(s,f),p.join(d,f)))\"",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js"
  },
  "dependencies": {
    "@clerk/express": "^2.1.6",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "nanoid": "^3.3.11",
    "pg": "^8.13.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.3.0"
  }
}
